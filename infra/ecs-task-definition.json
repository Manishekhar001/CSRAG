{
  "family": "csrag-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/csrag-task-role",
  "containerDefinitions": [
    {
      "name": "csrag",
      "image": "YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/csrag:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "API_HOST",                "value": "0.0.0.0" },
        { "name": "API_PORT",                "value": "8000" },
        { "name": "LOG_LEVEL",               "value": "INFO" },
        { "name": "ALLOWED_ORIGINS",         "value": "*" },
        { "name": "EMBEDDING_MODEL",         "value": "mxbai-embed-large" },
        { "name": "EMBEDDING_DIMENSION",     "value": "1024" },
        { "name": "COLLECTION_NAME",         "value": "csrag_documents" },
        { "name": "LLM_MODEL",               "value": "llama-3.3-70b-versatile" },
        { "name": "LLM_TEMPERATURE",         "value": "0.0" },
        { "name": "MEMORY_LLM_MODEL",        "value": "llama-3.3-70b-versatile" },
        { "name": "MEMORY_LLM_TEMPERATURE",  "value": "0.0" },
        { "name": "RETRIEVAL_K",             "value": "4" },
        { "name": "CHUNK_SIZE",              "value": "900" },
        { "name": "CHUNK_OVERLAP",           "value": "150" },
        { "name": "STM_MESSAGE_THRESHOLD",   "value": "6" },
        { "name": "CRAG_UPPER_THRESHOLD",    "value": "0.7" },
        { "name": "CRAG_LOWER_THRESHOLD",    "value": "0.3" },
        { "name": "SRAG_MAX_RETRIES",        "value": "2" },
        { "name": "MAX_REWRITE_TRIES",       "value": "2" },
        { "name": "TAVILY_MAX_RESULTS",      "value": "5" }
      ],
      "secrets": [
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:csrag/groq-api-key"
        },
        {
          "name": "QDRANT_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:csrag/qdrant-url"
        },
        {
          "name": "QDRANT_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:csrag/qdrant-api-key"
        },
        {
          "name": "TAVILY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:csrag/tavily-api-key"
        },
        {
          "name": "POSTGRES_URI",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:csrag/postgres-uri"
        },
        {
          "name": "OLLAMA_BASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:csrag/ollama-base-url"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/csrag",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import httpx; httpx.get('http://localhost:8000/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
