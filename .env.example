# ==============================================================================
# CSRAG — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Groq (LLM provider)
# Get your key at: https://console.groq.com
# ------------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------------------------
# Qdrant Cloud (Vector Store)
# Get your URL and key at: https://cloud.qdrant.io
# ------------------------------------------------------------------------------
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Collection name (will be auto-created on first run)
COLLECTION_NAME=csrag_documents

# ------------------------------------------------------------------------------
# Ollama (Local Embeddings — nomic-embed-text)
# Ollama must be running. Pull the model with:
#   ollama pull nomic-embed-text
# nomic-embed-text is used instead of mxbai-embed-large because it runs
# comfortably on t3.small (2GB RAM). mxbai-embed-large requires 2.5GB+.
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Dimension for nomic-embed-text is 768 (do not change unless switching models)
EMBEDDING_DIMENSION=768

# ------------------------------------------------------------------------------
# PostgreSQL (LTM store + STM checkpointer)
# Default points to the docker-compose Postgres instance.
# Update if using an external Postgres.
# ------------------------------------------------------------------------------
POSTGRES_URI=postgresql://postgres:postgres@localhost:5442/postgres?sslmode=disable

# ------------------------------------------------------------------------------
# Tavily (Web Search — CRAG fallback)
# Get your key at: https://app.tavily.com
# ------------------------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=5

# ------------------------------------------------------------------------------
# LLM Model Settings
# ------------------------------------------------------------------------------
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# Dedicated model for LTM memory extraction (can be the same as LLM_MODEL)
MEMORY_LLM_MODEL=llama-3.3-70b-versatile
MEMORY_LLM_TEMPERATURE=0.0

# ------------------------------------------------------------------------------
# Document Processing
# ------------------------------------------------------------------------------
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# ------------------------------------------------------------------------------
# Retrieval
# ------------------------------------------------------------------------------
RETRIEVAL_K=4

# ------------------------------------------------------------------------------
# Short-Term Memory
# Conversation is summarised when message count exceeds this threshold
# ------------------------------------------------------------------------------
STM_MESSAGE_THRESHOLD=6

# ------------------------------------------------------------------------------
# CRAG Thresholds
# ------------------------------------------------------------------------------
CRAG_UPPER_THRESHOLD=0.7
CRAG_LOWER_THRESHOLD=0.3

# ------------------------------------------------------------------------------
# SRAG Loop Limits
# ------------------------------------------------------------------------------
SRAG_MAX_RETRIES=2
MAX_REWRITE_TRIES=2

# ------------------------------------------------------------------------------
# API Server
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ------------------------------------------------------------------------------
# Logging
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins. Use * to allow all (dev only).
# Example: https://myapp.com,https://admin.myapp.com
# ------------------------------------------------------------------------------
ALLOWED_ORIGINS=*

# ------------------------------------------------------------------------------
# Application Info
# ------------------------------------------------------------------------------
APP_NAME=CSRAG — Corrective Self-Reflective RAG
APP_VERSION=0.1.0
